flowchart TD
    Start["Text activity entrypoint"]

    subgraph Incoming["Incoming message path"]
        Msg["New Discord text message"]
        Direct{"Direct mention, reply-to-bot,\nor exact bot name / alias?"}
        DirectPath["Immediate reply path"]
        Unsolicited{"permissions.replies.allowUnsolicitedReplies?"}
        RecentWindow{"Bot already in recent\nmessage window?"}
        RecentPath["Recent-window follow-up\ninteraction.activity.responseWindowEagerness shapes stickiness"]
        AmbientGate{"interaction.activity.ambientReplyEagerness\nadmits cold ambient reply?"}
        AmbientPath["Cold ambient reactive reply"]
        NoImmediate["No immediate reply\nmessage stored for continuity"]
    end

    subgraph Initiative["Unified text initiative"]
        Tick["60s in-process tick"]
        InitEnabled{"initiative.text.enabled\ncooldown met\ndaily cap available?"}
        EagerRoll{"initiative.text.eagerness\nprobability roll passed?"}
        ChannelPool["Eligible channels\npermissions.replies.replyChannelIds"]
        Context["Channel summaries\npassive feed candidates\nmemory + behavior guidance"]
        InitDecision["LLM decides whether to post,\nwhich channel fits,\nand whether to use tools/media"]
    end

    subgraph Shared["Shared global blockers"]
        Guardrails["permissions.replies.allowReplies\nmessage rate limits\nmin gap between messages\nsafety/runtime failure"]
    end

    Start --> Msg
    Start --> Tick

    Msg --> Direct
    Direct -->|Yes| DirectPath
    Direct -->|No| Unsolicited
    Unsolicited -->|No| NoImmediate
    Unsolicited -->|Yes| RecentWindow
    RecentWindow -->|Yes| RecentPath
    RecentWindow -->|No| AmbientGate
    AmbientGate -->|Yes| AmbientPath
    AmbientGate -->|No| NoImmediate

    Tick --> InitEnabled
    InitEnabled -->|No| NoInit["Skip this tick"]
    InitEnabled -->|Yes| EagerRoll
    EagerRoll -->|No| NoInit
    EagerRoll -->|Yes| ChannelPool
    ChannelPool --> Context
    Context --> InitDecision

    DirectPath --> Guardrails
    RecentPath --> Guardrails
    AmbientPath --> Guardrails
    InitDecision --> Guardrails
