flowchart TD
    subgraph Input["Stage 1: Audio Input"]
        DISC[Discord Voice Channel]
        OPUS[Opus decode to PCM]
        DISC --> OPUS
    end

    OPUS --> PATH{"voice.conversationPolicy.replyPath"}

    PATH -- native --> NATIVE_IN[Provider-native audio input]
    PATH -- bridge --> BRIDGE_ASR
    PATH -- brain --> BRAIN_ASR

    subgraph ASR["Stage 2: Transcription"]
        direction TB
        TRANS["voice.transcription.*"]
        BRIDGE_ASR["Bridge transcription\nagentStack.runtimeConfig.voice.openaiRealtime.*"]
        BRAIN_ASR["Brain-path transcription\nshared/file-turn ASR"]
    end

    subgraph GATES["Stage 3: Promotion + Noise Rejection"]
        direction TB
        G1["Promotion from provisional capture"]
        G2["Silence / short-clip filters"]
        G3["ASR confidence + hallucination guards"]
        G1 --> G2 --> G3
    end

    BRIDGE_ASR --> GATES
    BRAIN_ASR --> GATES

    subgraph ADMISSION["Stage 4: Reply Admission"]
        direction TB
        DET["Deterministic gates\nvoice.conversationPolicy.*\nvoice.admission.*"]
        CLASS["Classifier binding\nagentStack.overrides.voiceAdmissionClassifier\nor preset fallback"]
        DET --> CLASS
    end

    GATES --> ADMISSION
    ADMISSION -- deny --> DROP[Drop turn]
    ADMISSION -- allow --> GEN
    NATIVE_IN --> NATIVE_GEN

    subgraph NATIVE_GEN["Stage 5a: Native Planning"]
        NB["Provider-native planning\nand tool loop"]
    end

    subgraph GEN["Stage 5b/5c: Bridge or Brain Planning"]
        direction TB
        BRIDGE_GEN["Bridge: labeled text\nto realtime provider"]
        BRAIN_GEN["Brain: orchestrator text generation\nagentStack.runtimeConfig.voice.generation"]
    end

    subgraph TOOLS["Shared Tool Runtime"]
        direction TB
        T_MEM["memory_write\nconversation_search"]
        T_MUS["music_* controls"]
        T_WEB["web_search / browser_browse"]
        T_CODE["code_task / MCP tools"]
    end

    NATIVE_GEN <--> TOOLS
    GEN <--> TOOLS

    subgraph OUTPUT["Stage 6: Voice Output"]
        direction TB
        REALTIME["Realtime output transport"]
        API_TTS["API TTS override\nagentStack.runtimeConfig.voice.openaiAudioApi.*"]
        DISCORD["Discord playback"]
        REALTIME --> DISCORD
        API_TTS --> DISCORD
    end

    GEN --> OUTPUT
    NATIVE_GEN --> OUTPUT

    subgraph THOUGHT["Voice Thought Engine (Parallel)"]
        direction TB
        SILENCE["initiative.voice.* cadence"]
        TGEN["Thought generation\ncurrent binding follows orchestrator"]
        TDEC["Allow / reject + memory"]
        SILENCE --> TGEN --> TDEC
        TDEC -- allow --> OUTPUT
    end

    classDef stage fill:#1a3a4a,stroke:#3a7a9a,stroke-width:2px
    classDef drop fill:#4a2d2d,stroke:#8c4a4a
    classDef thought fill:#3a3a1a,stroke:#7a7a3a,stroke-width:2px,stroke-dasharray: 5 5

    class Input,ASR,GATES,ADMISSION,GEN,NATIVE_GEN,OUTPUT stage
    class THOUGHT thought
    class DROP drop
